NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
# 쉼표로 구분된 CIDR (G-D72). 미설정 시 모든 IP 허용.
# 예: 1.2.3.0/24,5.6.7.8
TOSS_WEBHOOK_ALLOWED_IPS=
RESEND_API_KEY=
CRON_SECRET=
OTP_JWT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_DOMAIN=supporters.kr

# 개발용 로그인 우회. "1"로 설정하면 /donor/login에 목업 폼 노출
# (고정 코드 000000, 아무 이메일/연락처로 member 자동 생성).
# NODE_ENV=production에선 자동 무시되지만 실수 방지를 위해 prod .env에는 넣지 말 것.
NEXT_PUBLIC_DONOR_AUTH_BYPASS=

# SP-1: PostHog Web Vitals 서버 측 전송 (선택)
# 미설정 시 /api/observability/web-vitals는 reportEvent 로그만 남김 (안전 no-op).
# 활성화: https://app.posthog.com Project API Key(phc_...) 복사.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# SP-5: 민감 작업 재인증 토큰 HMAC 시크릿 (프로덕션 필수)
# 생성: openssl rand -hex 32
# 미설정 시 개발용 기본값 사용 → 프로덕션에서는 반드시 교체.
REAUTH_SECRET=
